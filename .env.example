# Google Tag Manager ID (currently hardcoded in src/index.js and public/index.html)
# REACT_APP_GTM_ID=GTM-XXXXXXX

# No environment variables are strictly required to run the project locally.
# The app works out of the box with `npm start`.
#
# If you add API keys or secrets in the future, document them here.
# CRA exposes variables prefixed with REACT_APP_ to the browser.
# NEVER commit actual .env files with secrets.
