{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://code.iconify.design https://cdnjs.cloudflare.com https://www.googletagmanager.com https://api.iconify.design; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; font-src 'self' data:; connect-src 'self' https://api.iconify.design https://www.google-analytics.com https://www.googletagmanager.com; frame-src https://www.googletagmanager.com; base-uri 'self'; form-action 'self'" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=UTF-8" }
      ]
    },
    {
      "source": "/image-sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=UTF-8" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/entity.html",
      "destination": "/entity.html"
    },
    {
      "source": "/image-ownership.html",
      "destination": "/image-ownership.html"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/image-sitemap.xml",
      "destination": "/image-sitemap.xml"
    },
    {
      "source": "/about",
      "destination": "/index.html"
    },
    {
      "source": "/projects",
      "destination": "/index.html"
    },
    {
      "source": "/resume",
      "destination": "/index.html"
    },
    {
      "source": "/experience",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
